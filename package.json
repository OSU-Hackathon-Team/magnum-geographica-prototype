{
  "name": "magnum",
  "version": "0.0.1",
  "devDependencies": {
    "@jest/reporters": "^30.4.1",
    "@playwright/test": "^1.61.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "detox": "^20.35",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jest": "^29",
    "jest-circus": "^30.4.2",
    "jest-cli": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "description": "Magnum - Wikipedia for trails. A community-edited atlas of trails with offline-first mobile + web.",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "license": "AGPL-3.0",
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:root": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "build:e2e": "cd packages/app && EXPO_PUBLIC_API_URL=\"${EXPO_PUBLIC_API_URL:-http://localhost:9999}\" bunx expo export --platform web --output-dir ../../tests/e2e/.app",
    "detox:build-android:debug": "detox build --configuration android.emu.debug",
    "detox:build-android:release": "detox build --configuration android.emu.release",
    "detox:test-android:debug": "detox test --configuration android.emu.debug",
    "detox:test-android:release": "detox test --configuration android.emu.release",
    "detox:test-android:debug:ci": "CI=true detox test --configuration android.emu.debug --cleanup --artifacts-location e2e/.results/",
    "set-role": "bun run --cwd packages/api set-role",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@transistorsoft/background-geolocation-types": "5.2.0"
  }
}
