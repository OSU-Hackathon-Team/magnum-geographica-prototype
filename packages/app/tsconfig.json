{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["react-native", "expo-router"],
    "moduleResolution": "bundler",
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"],
      "@magnum/shared": ["../shared/src/index.ts"],
      "@magnum/shared/*": ["../shared/src/*"],
      "@magnum/map": ["../map/src/index.ts"],
      "@magnum/map/*": ["../map/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules", "dist", ".expo", "test"]
}
