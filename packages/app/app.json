{
  "expo": {
    "name": "Magnum",
    "slug": "magnum",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "magnum",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "platforms": ["ios", "android", "web"],
        "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.magnum.app"
    },
    "android": {
      "package": "org.magnum.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "@config-plugins/detox",
      [
        "react-native-background-geolocation",
        {
          "license": {
            "appId": "org.magnum.app",
            "entitlements": ["core"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
