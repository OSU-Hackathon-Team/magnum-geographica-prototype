{
  "expo": {
    "name": "Magnum",
    "slug": "magnum",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "magnum",
    "userInterfaceStyle": "automatic",
    "main": "./index.js",
    "newArchEnabled": false,
    "platforms": ["ios", "android", "web"],
        "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.magnum.app"
    },
    "android": {
      "package": "org.magnum.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "@config-plugins/detox",
      [
        "react-native-background-geolocation",
        {
          "license": "{\"app_id\":\"org.magnum.app\",\"entitlements\":[\"core\",\"polygon-geofencing\",\"firebase\",\"hms\"]}"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
