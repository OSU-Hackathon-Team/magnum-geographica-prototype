{
  "name": "@magnum/app",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform all",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src app --ext .ts,.tsx",
    "test": "echo 'test: app (no tests yet)'",
    "clean": "rm -rf .expo .turbo dist node_modules/.cache"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@expo/metro-config": "~0.19.0",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.4",
    "@magnum/map": "workspace:*",
    "@magnum/shared": "workspace:*",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.3",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.9",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "babel-preset-expo": "^56.0.15",
    "typescript": "^5.7.2"
  }
}
