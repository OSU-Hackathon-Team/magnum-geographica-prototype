{
  "name": "@magnum/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --external pg --external postgres",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "bun run src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run src/seed.ts",
    "clean": "rm -rf dist .turbo drizzle"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.1",
    "@magnum/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "bun-types": "latest",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
