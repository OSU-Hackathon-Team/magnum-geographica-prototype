DB_HOST=localhost
DB_PORT=5432
DB_NAME=magnum
DB_USER=magnum
DB_PASSWORD=changeme

MARTIN_URL=http://localhost:3001
API_PORT=3000

ADMIN_SECRET=dev-secret-change-me
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_MARTIN_URL=http://localhost:3001

# Android emulator: the `bun run --cwd packages/app android` script runs
# `adb reverse tcp:3000 tcp:3000` and `adb reverse tcp:8081 tcp:8081`
# automatically so that localhost works from inside the emulator.
# If adb is unavailable, override these to 10.0.2.2 (host alias):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# EXPO_PUBLIC_MARTIN_URL=http://10.0.2.2:3001

NODE_ENV=development
