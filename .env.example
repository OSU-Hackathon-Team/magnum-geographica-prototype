# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=magnum
DB_USER=magnum
DB_PASSWORD=changeme

# Host-side ports (mapped into containers). Change these to run multiple
# Magnum instances in parallel. Use `./scripts/ports.sh` to manage them.
POSTGRES_HOST_PORT=5432
MARTIN_HOST_PORT=3001
API_HOST_PORT=3000
METRO_HOST_PORT=8081

# Docker Compose project name. Containers, networks, and the postgres volume
# are all prefixed with this, so each instance is fully isolated.
COMPOSE_PROJECT_NAME=magnum

# Internal-facing service URLs (used by the API at runtime). These are
# rewritten automatically by `scripts/ports.sh` when host ports change.
MARTIN_URL=http://localhost:3001
API_PORT=3000

ADMIN_SECRET=dev-secret-change-me
# CORS_ORIGINS is rewritten automatically by `scripts/ports.sh` to include
# the current API and Metro host ports.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Client-facing URLs (inlined into the mobile bundle at build time).
# These are rewritten automatically by `scripts/ports.sh` when host ports
# change. If you change them by hand, rebuild the APK to pick them up.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_MARTIN_URL=http://localhost:3001

# Android emulator: the `bun run --cwd packages/app android` script runs
# `adb reverse tcp:3000 tcp:3000` and `adb reverse tcp:8081 tcp:8081`
# automatically so that localhost works from inside the emulator.
# If adb is unavailable, override these to 10.0.2.2 (host alias):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# EXPO_PUBLIC_MARTIN_URL=http://10.0.2.2:3001

NODE_ENV=development
MARTIN_CACHE_MB=0
